  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next build && portless ncdai next start",
    "check-types": "tsc --noEmit --pretty",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "registry:build": "vp dlx tsx ./src/scripts/build-registry.mts && shadcn build ./src/__registry__/registry.autogenerated.json",
    "capture": "vp dlx tsx ./src/scripts/capture.mts",
    "generate-libphonenumber-metadata": "libphonenumber-metadata-generator ./src/assets/libphonenumber.metadata.json --countries VN --extended",
    "upgrade:next": "vp dlx @next/codemod@latest upgrade latest",
    "upgrade:tailwind": "vp dlx @tailwindcss/upgrade@latest"
  },
